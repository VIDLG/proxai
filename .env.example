# Copy this file to .env and fill in local values.
# Do not commit .env.

# Upstream OpenAI-compatible base URL, without the /v1 suffix.
OPENAI_SHIM_UPSTREAM=http://your-upstream.example:8080

# Optional. Used when the client does not send Authorization, or when
# OPENAI_SHIM_OVERRIDE_AUTHORIZATION=true.
OPENAI_SHIM_API_KEY=replace-with-your-api-key

# Set to true if Zed must send a dummy key but the shim should use the key above.
OPENAI_SHIM_OVERRIDE_AUTHORIZATION=false

# Optional local listen and timeout settings.
OPENAI_SHIM_HOST=127.0.0.1
OPENAI_SHIM_PORT=18080
OPENAI_SHIM_TIMEOUT_SECONDS=300
OPENAI_SHIM_LOG_LEVEL=INFO
